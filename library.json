{
  "name": "arduino4iot",
  "version": "2.0.0",
  "description": "ESP32 client library for the x4iot system: provisioning, telemetry, logging, configuration and OTA firmware updates with a nice4iot server",
  "keywords": ["iot", "api", "esp32", "arduino", "nice4iot", "telemetry", "ota"],
  "repository": {
    "type": "git",
    "url": "https://github.com/clausgf/arduino4iot"
  },
  "authors": [
    {
      "name": "clausgf@github.com"
    }
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": "espressif32",
  "headers": "iot.h",
  "dependencies": {
    "bblanchon/ArduinoJson": "^7.0.0"
  },
  "export": {
    "exclude": [
      ".github",
      "test",
      "platformio.ini"
    ]
  },
  "build": {
    "srcDir": "src",
    "includeDir": "include"
  }
}
